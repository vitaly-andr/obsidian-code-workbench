{# nginx vhost rendered by Ansible #}
server {
    listen {{ http_port | default(80) }};
    server_name {{ domain }};
    {% for path in static_paths %}
    location {{ path }} {
        root {{ web_root }};
    }
    {% endfor %}
    {% if ssl_enabled %}
    ssl_certificate {{ cert_path }};
    {% endif %}
}
